# Домен берётся из переменной APP_DOMAIN (см. .env). Она пробрасывается в
# caddy-контейнер через docker-compose.yml. Меняешь домен — правишь только
# .env, этот файл трогать не нужно.
{$APP_DOMAIN}, www.{$APP_DOMAIN} {
    encode zstd gzip

    # WebSocket совместного редактирования и чата живёт на ОТДЕЛЬНОМ порту
    # (collab-сервер в server.ts, по умолчанию PORT+1=3001). Префикс пути не
    # срезаем (collab-сервер проверяет /api/collaboration) — поэтому handle, а не
    # handle_path. Апгрейд WebSocket Caddy проксирует автоматически. Порт 3001 на
    # хост не публикуется — ходим к app:3001 внутри docker-сети.
    handle /api/collaboration/* {
        reverse_proxy app:3001
    }

    handle {
        reverse_proxy app:3000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
