DATABASE_URL=postgresql://taskflow:password@db:5432/taskflow

# Домен сайта без https:// — Caddy выпускает на него TLS-сертификат,
# DNS-записи A для @ и www должны указывать на IP сервера.
APP_DOMAIN=taskflow.ru

BETTER_AUTH_SECRET=generate-via-openssl-rand
# должен совпадать с APP_DOMAIN
BETTER_AUTH_URL=https://taskflow.ru
# тот же URL, доступен в браузере (auth-client). Локально для OAuth: http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=https://taskflow.ru

# Яндекс ID (OAuth). Кнопка входа появляется только когда оба значения заданы.
# Redirect URI в кабинете Яндекса: <BETTER_AUTH_URL>/api/auth/oauth2/callback/yandex
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@taskflow.ru
SMTP_PASSWORD=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

POSTGRES_USER=taskflow
POSTGRES_PASSWORD=password
POSTGRES_DB=taskflow

# Demo-режим — включает быстрый вход без почты/OAuth.
# Работает только если в базе есть демо-пользователи (npm run db:seed).
# Для production — оставьте пустым или false.
DEMO_MODE=true
